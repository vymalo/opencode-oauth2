# Store-submission credentials for `wxt submit` (used by the submit:chrome /
# submit:firefox scripts). Copy to `.env.submit` and fill in — `.env.submit` is
# gitignored. In CI these are GitHub repository secrets, not this file.
#
# Each store is independent: fill only the block you've set up. See
# docs/browser.md → "Publishing the extension to the web stores".

# --- Chrome Web Store -------------------------------------------------------
# Item ID from the Developer Dashboard, and an OAuth client (Google Cloud) with
# the Chrome Web Store API enabled. https://wxt.dev/guide/essentials/publishing
CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# --- Firefox Add-ons (AMO) --------------------------------------------------
# Add-on UUID (gecko.id) + API key pair from
# https://addons.mozilla.org/developers/addon/api/key/
FIREFOX_EXTENSION_ID=
FIREFOX_JWT_ISSUER=
FIREFOX_JWT_SECRET=
