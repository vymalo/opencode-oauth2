{
  "name": "@vymalo/opencode-code-index",
  "version": "0.8.0",
  "private": true,
  "description": "Personal OpenCode plugin that indexes a repository into an embedded DuckDB store and exposes code_* tools (symbol, callers, callees, references, blast_radius) backed by a tree-sitter symbol graph. Content-addressed by git blob and scoped per branch, so branch/worktree switches re-index only the delta.",
  "license": "MIT",
  "author": "vymalo contributors",
  "homepage": "https://github.com/vymalo/opencode-oauth2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vymalo/opencode-oauth2.git",
    "directory": "packages/opencode-code-index"
  },
  "bugs": {
    "url": "https://github.com/vymalo/opencode-oauth2/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "code-index",
    "tree-sitter",
    "duckdb",
    "call-graph"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.3",
    "@opencode-ai/plugin": "1.15.10",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
